pacman -Sy
pacman -Sy archlinux-keyring

cfdisk /dev/nvme0n1
boot :- EFI System
swap :- Linux swap
root :- Linux filesystem

mkfs.fat -F32 /dev/nvme0n1p1
mkfs.ext4 /dev/nvme0n1p3
mkswap /dev/nvme0n1p2

mount /dev/nvme0n1p3 /mnt
mkdir /mnt/boot
mount /dev/nvme0n1p1 /mnt/boot/
swapon /dev/nvme0n1p2

pacstrat -i /mnt base base-devel linux linux-firmware linux-headers intel-ucode grub efibootmgr git vim neofetch networkmanager bluez bluez-utils

genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt

ln -sf /usr/share/zoneinfo/Asia/Kolkata /etc/localtime
hwclock --systohc

#uncomment locales from "/etc/locale.gen"
locale-gen
add en_IN to "/etc/locale.conf"

add hostname to "/etc/hostname"
passwd
useradd -m -g users -G wheel,storage,power,video,audio -s /bin/bash kalyan

pacman -S dosfstools mtools
grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id="Grub Bootloader"
grub-mkconfig -o /boot/grub/grub.cfg

systemctl enable bluetooth
systemctl enable NetworkManager

make changes in "/etc/pacman.conf /etc/makepkg.conf /etc/default/grub"

exit
umount -lR /mnt
shutdown now

sudo pacman -Syu

# For dualbooting Windows 
sudo pacman -Sy os-prober

sudo edit "/etc/default/grub" uncomment "DISABLE_OS_PROBER=false"
sudo grub-mkconfig -o /boot/grub/grub.cfg

